{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome: site local",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5500/index.html"
    },
    {
      "name": "Python: gerar_foto.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/gerar_foto.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
